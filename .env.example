# Signal Environment Variables
NEXT_PUBLIC_APP_URL=http://localhost:3000
SUPABASE_URL=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
FUNDAMENTALS_SEED_TOKEN=
APP_ADMIN_TOKEN=
APP_SETTINGS_ENCRYPTION_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# LLM provider switching
# deepseek: uses DEEPSEEK_API_KEY / DEEPSEEK_BASE_URL
# openai-compatible: uses LLM_API_KEY / LLM_BASE_URL and works with OpenAI-compatible gateways
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=deepseek-chat
LLM_REASONING_MODEL=deepseek-chat
LLM_WORKER_MODEL=deepseek-chat
LLM_CRITIC_MODEL=deepseek-chat
LLM_REASONING_TEMPERATURE=0.3
LLM_CRITIC_TEMPERATURE=0.5
LLM_INPUT_COST_PER_MILLION=0
LLM_OUTPUT_COST_PER_MILLION=0
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_USER_ID=
YFINANCE_PROXY_URL=
APP_TIMEZONE=Asia/Tokyo
DAILY_LLM_COST_LIMIT_USD=3

# Deployment automation only; do not expose these to the browser.
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
SUPABASE_CREATE_PROJECT=0
SUPABASE_ORG_ID=
SUPABASE_PROJECT_NAME=signal
SUPABASE_REGION=ap-northeast-1
SUPABASE_SIZE=nano
SUPABASE_DB_PASSWORD=
VERCEL_TOKEN=
VERCEL_PROJECT_NAME=signal
VERCEL_TEAM_ID=
VERCEL_TEAM_SLUG=
VERCEL_ENVIRONMENTS=production,preview,development

# App login
SIGNAL_AUTH_ALLOWED_EMAILS=
